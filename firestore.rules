rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default deny all
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Core Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() 
        && request.auth.token.email_verified == true 
        && request.auth.token.email == 'deiorbo@gmail.com'; 
    }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprint for Service
    function isValidService(data) {
      return data.keys().hasAll(['title', 'description', 'icon', 'order'])
        && data.keys().size() == 4
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 2000
        && data.icon is string && data.icon.size() <= 100
        && data.order is number;
    }

    // Validation Blueprint for FAQ
    function isValidFAQ(data) {
      return data.keys().hasAll(['question', 'answer', 'order'])
        && data.keys().size() == 3
        && data.question is string && data.question.size() <= 500
        && data.answer is string && data.answer.size() <= 5000
        && data.order is number;
    }

    // Validation Blueprint for Testimonial
    function isValidTestimonial(data) {
      return data.keys().hasAll(['name', 'title', 'quote', 'image', 'order'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() <= 200
        && data.title is string && data.title.size() <= 200
        && data.quote is string && data.quote.size() <= 2000
        && data.image is string && data.image.size() <= 500
        && data.order is number;
    }

    // Validation Blueprint for Site Content (About, Settings)
    function isValidContent(sectionId, data) {
      return (sectionId == 'about' && data.keys().hasAll(['text']) && data.keys().size() == 1 && data.text is string)
        || (sectionId == 'settings' && data.keys().hasAll(['phone', 'email', 'location', 'whatsapp', 'facebook', 'instagram']) && data.keys().size() == 6 && data.email is string);
    }

    match /services/{serviceId} {
      allow get: if isValidId(serviceId);
      allow list: if true;
      allow create: if isAdmin() && isValidId(serviceId) && isValidService(incoming());
      allow update: if isAdmin() && isValidId(serviceId) && isValidService(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'icon', 'order'])
      );
      allow delete: if isAdmin() && isValidId(serviceId);
    }

    match /faqs/{faqId} {
      allow get: if isValidId(faqId);
      allow list: if true;
      allow create: if isAdmin() && isValidId(faqId) && isValidFAQ(incoming());
      allow update: if isAdmin() && isValidId(faqId) && isValidFAQ(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['question', 'answer', 'order'])
      );
      allow delete: if isAdmin() && isValidId(faqId);
    }

    match /testimonials/{testimonialId} {
      allow get: if isValidId(testimonialId);
      allow list: if true;
      allow create: if isAdmin() && isValidId(testimonialId) && isValidTestimonial(incoming());
      allow update: if isAdmin() && isValidId(testimonialId) && isValidTestimonial(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'title', 'quote', 'image', 'order'])
      );
      allow delete: if isAdmin() && isValidId(testimonialId);
    }

    match /content/{sectionId} {
      allow read: if true;
      allow write: if isAdmin() && isValidContent(sectionId, incoming());
    }
  }
}
